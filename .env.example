# ============================================================
# Local Devnet (default)
# ============================================================
# These values work out of the box with a local Hardhat devnet.

# Funded private key for proxy signing (Hardhat dev key)
PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"

# Private key for deployments and contract calls (Hardhat dev key)
PRIV_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"

# Initial owner address (derived from PRIV_KEY)
INITIAL_OWNER="0xF4E021377420Afe90c1A7D2b8968904946633a64"

# Docker image registry (defaults to "local" for locally-built images)
# REGISTRY=registry.gitlab.com/flarenetwork/tee/e2e

# ============================================================
# Coston2 Testnet
# ============================================================
# To deploy on Coston2 instead of local devnet, uncomment and
# fill in the values below. Then run the same scripts as usual:
#   ./scripts/full-setup.sh --test
# Or for Docker:
#   docker compose -f docker-compose.yaml -f docker-compose.coston2.yaml up -d

# CHAIN_URL=https://coston2-api.flare.network/ext/C/rpc
# ADDRESSES_FILE=./config/coston2/deployed-addresses.json
# PRIV_KEY=<your-funded-coston2-private-key>
# PRIVATE_KEY=<proxy-signing-key>
# INITIAL_OWNER=<address-derived-from-PRIV_KEY>
# LOCAL_MODE=false
# NORMAL_PROXY_URL=<coston2-ftdc-proxy-url>
# EXT_PROXY_URL=http://localhost:6674
# PROXY_CONFIG=./config/proxy/extension_proxy.coston2.toml
