# --- Deployer / Signing Keys ---

# Funded private key for proxy signing (Hardhat dev key shown as default)
PROXY_PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"

# Private key for deployments and on-chain calls (must be funded on target chain).
# Derive the address: cast wallet address --private-key $DEPLOYMENT_PRIVATE_KEY
#
# Devnet (Hardhat):
# DEPLOYMENT_PRIVATE_KEY="983760a4ebf75b2ac3a93531168a0f225d01e5dc6e3568adbd46233ba1fb4fa4"
# INITIAL_OWNER="0xF4E021377420Afe90c1A7D2b8968904946633a64"
#
# Coston2 (replace with your own):
INITIAL_OWNER="0x123.."
DEPLOYMENT_PRIVATE_KEY="123..."

# --- Chain & Contracts ---

# Chain RPC URL
CHAIN_URL=https://coston2-api.flare.network/ext/C/rpc

# Path to deployed FCC registry contract addresses
ADDRESSES_FILE=./config/coston2/deployed-addresses.json

# Must be false on live networks
LOCAL_MODE=false

# --- TEE ---

# TEE attestation mode: true = use test code hash/platform (no real TEE hardware)
# Set to false when running on actual GCP Confidential VM with real attestation
SIMULATED_TEE=true

# --- Orderbook Extension ---

# Comma-separated admin addresses for the TEE-side extension.
# Admins can use EXPORT_HISTORY to query other users' data.
# Typically set to the deployer address.
ADMIN_ADDRESSES="0x123.."

# --- Direct Instructions ---

# API key for the proxy's /direct endpoint (must match proxy config)
DIRECT_API_KEY=test-api-key-change-me

# --- Proxy URLs ---

# Normal/FTDC proxy URL on Coston2
NORMAL_PROXY_URL=https://tee-proxy-coston2-1.flare.rocks

# Extension proxy URL (auto-detected by scripts if unset)
# Docker: http://localhost:6674 | Local Go: http://localhost:6664 | Remote: ngrok URL
# EXT_PROXY_URL=http://localhost:6674
EXT_PROXY_URL=https://<your-ngrok-url>.ngrok-free.dev

# --- Docker ---

# Docker image registry (defaults to "local" for locally-built images)
# Uncomment to use remote registry:
# REGISTRY=registry.gitlab.com/flarenetwork/tee/e2e
