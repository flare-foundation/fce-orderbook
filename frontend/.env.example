# TEE proxy URL.
#
# For local dev: leave empty so the frontend uses relative URLs; vite's dev
# server proxies /direct, /state, /action to VITE_PROXY_UPSTREAM (see below),
# avoiding CORS entirely because the browser only sees same-origin requests.
#
# For production (or a built bundle served outside vite): set this to the
# publicly-reachable cors-proxy URL, e.g. http://localhost:6670.
# Note: Chrome blocks ports 6665-6669 (IRC range); use 6670+ for cors-proxy.
VITE_TEE_PROXY_URL=

# Upstream TEE proxy that vite's dev proxy forwards to.
# Docker mode (default):   http://localhost:6674
# Local Go process mode:   http://localhost:6664
VITE_PROXY_UPSTREAM=http://localhost:6674

# API key for the proxy's /direct endpoint
VITE_DIRECT_API_KEY=test-api-key-change-me

# Show the faucet button (set to false to hide in production)
VITE_SHOW_FAUCET=true

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
