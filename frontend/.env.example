# TEE proxy URL (cors-proxy in dev, direct proxy URL in production)
VITE_TEE_PROXY_URL=http://localhost:6665

# API key for the proxy's /direct endpoint
VITE_DIRECT_API_KEY=test-api-key-change-me

# Show the faucet button (set to false to hide in production)
VITE_SHOW_FAUCET=true

# WalletConnect project ID (get one at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
